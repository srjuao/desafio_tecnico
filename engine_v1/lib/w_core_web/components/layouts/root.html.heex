<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="WCore" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <script src="https://cdn.tailwindcss.com"></script>

    <script defer src="/vendor/phoenix/phoenix.js"></script>
    <script defer src="/vendor/phoenix_live_view/phoenix_live_view.js"></script>

    <script type="text/javascript">
      const Iridescence = {
        mounted() {
          const colors = JSON.parse(this.el.dataset.color || '[0, 0, 0]')
          const speed = parseFloat(this.el.dataset.speed || '1.0')
          const amplitude = parseFloat(this.el.dataset.amplitude || '1.0')

          // Setup canvas
          const canvas = document.createElement('canvas')
          canvas.style.position = 'absolute'
          canvas.style.top = '0'
          canvas.style.left = '0'
          canvas.style.width = '100%'
          canvas.style.height = '100%'
          canvas.style.zIndex = '0'
          this.el.appendChild(canvas)
          
          const gl = canvas.getContext('webgl')
          if (!gl) return // Falta Suporte WebGL
          // ... WebGL simplificado
          const vs = gl.createShader(gl.VERTEX_SHADER)
          gl.shaderSource(vs, `attribute vec2 p; void main() { gl_Position = vec4(p, 0.0, 1.0); }`)
          gl.compileShader(vs)

          const fs = gl.createShader(gl.FRAGMENT_SHADER)
          gl.shaderSource(fs, `
            precision mediump float;
            uniform float t;
            uniform vec3 c;
            uniform vec2 res;
            
            void main() {
              vec2 uv = gl_FragCoord.xy / res.xy;
              float pattern = sin(uv.x * 10.0 + t) * cos(uv.y * 10.0 - t);
              vec3 final_color = c * (0.5 + 0.5 * pattern) * 0.2; // Escuro e discreto
              gl_FragColor = vec4(final_color, 1.0);
            }
          `)
          gl.compileShader(fs)

          const program = gl.createProgram()
          gl.attachShader(program, vs)
          gl.attachShader(program, fs)
          gl.linkProgram(program)
          gl.useProgram(program)

          const buffer = gl.createBuffer()
          gl.bindBuffer(gl.ARRAY_BUFFER, buffer)
          gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]), gl.STATIC_DRAW)
          
          const pLoc = gl.getAttribLocation(program, 'p')
          gl.enableVertexAttribArray(pLoc)
          gl.vertexAttribPointer(pLoc, 2, gl.FLOAT, false, 0, 0)

          const tLoc = gl.getUniformLocation(program, 't')
          const cLoc = gl.getUniformLocation(program, 'c')
          const resLoc = gl.getUniformLocation(program, 'res')

          gl.uniform3f(cLoc, colors[0]/255, colors[1]/255, colors[2]/255)

          let start = Date.now()
          const draw = () => {
             canvas.width = this.el.clientWidth
             canvas.height = this.el.clientHeight
             gl.viewport(0, 0, canvas.width, canvas.height)
             gl.uniform2f(resLoc, canvas.width, canvas.height)
             gl.uniform1f(tLoc, (Date.now() - start) * 0.001 * speed)
             gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4)
             this.req = requestAnimationFrame(draw)
          }
          draw()
        },
        destroyed() {
          cancelAnimationFrame(this.req)
        }
      };

      // Add a DOMContentLoaded listener to initialize the LiveSocket after the scripts are loaded
      window.addEventListener("DOMContentLoaded", () => {
        const Socket = window.Phoenix.Socket;
        const LiveSocket = window.Phoenix.LiveView.LiveSocket;
        let csrfToken = document.querySelector("meta[name='csrf-token']").getAttribute("content")
        let liveSocket = new LiveSocket("/live", Socket, {
          params: {_csrf_token: csrfToken},
          hooks: { Iridescence }
        })
        liveSocket.connect()
        window.liveSocket = liveSocket
      });
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body class="bg-black text-white antialiased h-screen w-screen overflow-x-hidden">
    {@inner_content}
  </body>
</html>
